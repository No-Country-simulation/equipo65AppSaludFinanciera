# Copia este archivo como .env. Sin secretos: el repo es publico.

# Fuente de datos de las pantallas (ADR-0011): mock | api
EXPO_PUBLIC_DATA_SOURCE=mock

# URL de la API publica (con DATA_SOURCE=api).
# En el emulador Android, 10.0.2.2 = localhost de tu maquina.
EXPO_PUBLIC_API_URL=http://10.0.2.2:8080/api/v1
