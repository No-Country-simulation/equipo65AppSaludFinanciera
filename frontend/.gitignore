# =============================================================
#  EL REPOSITORIO ES PUBLICO.
#  Un secreto commiteado aqui se considera COMPROMETIDO PARA
#  SIEMPRE, aunque se borre en el commit siguiente: los bots de
#  escaneo lo encuentran en minutos y el historial lo conserva.
#  Si pasa: (1) ROTAR el secreto, (2) revocarlo, (3) recien
#  despues limpiar el historial. Ver docs/seguridad/SEGURIDAD.md
# =============================================================

# --- SECRETOS: nada de esto entra al repo, jamas ---
.env
*.env
.env.*
!.env.ejemplo

# Wallet de Oracle Autonomous Database (certificados mTLS)
wallet*.zip
wallet/
Wallet_*/
tnsnames.ora
sqlnet.ora
cwallet.sso
ewallet.p12

# Llaves de API de OCI
.oci/
oci_api_key*.pem

# Claves y certificados en general
*.pem
*.key
*.p12
*.pfx
*.jks
!**/test/**/*.pem

# Terraform: el tfstate contiene la CONTRASENA DE LA BD EN CLARO
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.ejemplo
.terraform/
.terraform.lock.hcl
crash.log

# Ansible
*.retry
inventario/oci.yml
vault_pass.txt

